    @Test
    fun addAllGenericList() {
        val original = mutablePKeyListOf(1KeySuffix, 2KeySuffix)
        val toAdd = mutableListOf(3KeySuffix, 4KeySuffix, 5KeySuffix)
        
        assertTrue(original.addAll(toAdd))
        assertEquals(5, original.size)
        assertEquals(list, original)
        
        // Test adding empty list
        assertFalse(original.addAll(mutableListOf()))
        assertEquals(5, original.size)
        assertEquals(list, original)
        
        // Test adding to empty list
        val empty = mutablePKeyListOf()
        assertTrue(empty.addAll(toAdd))
        assertEquals(mutablePKeyListOf(3KeySuffix, 4KeySuffix, 5KeySuffix), empty)
        
        // Test capacity expansion
        val small = MutablePKeyList(2)
        small.add(1KeySuffix)
        assertTrue(small.addAll(mutableListOf(2KeySuffix, 3KeySuffix, 4KeySuffix)))
        assertEquals(mutablePKeyListOf(1KeySuffix, 2KeySuffix, 3KeySuffix, 4KeySuffix), small)
    }

