        val l2 = mutablePKeyListOf(1KeySuffix, 2KeySuffix)
        val l3 = mutablePKeyListOf(5KeySuffix)
        val l4 = mutablePKeyListOf(3KeySuffix)
        assertTrue(l4.addAll(1, l3))
