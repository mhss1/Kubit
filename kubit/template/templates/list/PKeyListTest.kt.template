    @Test
    fun all() {
        assertTrue(list.all { it > 0KeySuffix })
        assertTrue(list.all { it < 6KeySuffix })
        assertFalse(list.all { it < 5KeySuffix })
        assertFalse(list.all { it > 3KeySuffix })
        
        assertTrue(mutablePKeyListOf().all { it > 0KeySuffix })
        
        assertTrue(mutablePKeyListOf(1KeySuffix).all { it == 1KeySuffix })
        assertFalse(mutablePKeyListOf(1KeySuffix).all { it == 2KeySuffix })
        
        val duplicates = mutablePKeyListOf(2KeySuffix, 2KeySuffix, 2KeySuffix)
        assertTrue(duplicates.all { it == 2KeySuffix })
        
        var count = 0
        assertFalse(list.all { 
            count++
            it > 3KeySuffix 
        })
        assertTrue(count < list.size)
    }

    @Test
    fun reversedAll() {
        assertTrue(list.reversedAll { it < 6KeySuffix })
        assertTrue(list.reversedAll { it > 0KeySuffix })
        assertFalse(list.reversedAll { it > 3KeySuffix })
        assertFalse(list.reversedAll { it < 3KeySuffix })
        
        assertTrue(mutablePKeyListOf().reversedAll { it > 0KeySuffix })
        
        assertTrue(mutablePKeyListOf(1KeySuffix).reversedAll { it == 1KeySuffix })
        assertFalse(mutablePKeyListOf(1KeySuffix).reversedAll { it == 2KeySuffix })
        
        val duplicates = mutablePKeyListOf(2KeySuffix, 2KeySuffix, 2KeySuffix)
        assertTrue(duplicates.reversedAll { it == 2KeySuffix })
        
        val evaluated = mutablePKeyListOf()
        assertTrue(list.reversedAll { 
            evaluated.add(it)
            true
        })
        assertEquals(mutablePKeyListOf(5KeySuffix, 4KeySuffix, 3KeySuffix, 2KeySuffix, 1KeySuffix), evaluated)
        
        var count = 0
        assertFalse(list.reversedAll { 
            count++
            it < 3KeySuffix 
        })
        assertTrue(count < list.size)
    }
    
