    fun firstLastOrNull() {
        val d = PKeyDeque(2)
        assertNull(d.firstOrNull())
        assertNull(d.lastOrNull())
        d.addLast(5KeySuffix)
        assertEquals(5KeySuffix, d.firstOrNull())
        assertEquals(5KeySuffix, d.lastOrNull())
        d.addFirst(4KeySuffix)
        assertEquals(4KeySuffix, d.firstOrNull())
        assertEquals(5KeySuffix, d.lastOrNull())
    }

    @Test
    fun sizeAndLastIndex() {
        val d = PKeyDeque(1)
        assertEquals(-1, d.lastIndex)
        d.addLast(1KeySuffix)
        assertEquals(0, d.lastIndex)
        d.addLast(2KeySuffix)
        assertEquals(1, d.lastIndex)
        d.removeFirst()
        assertEquals(0, d.lastIndex)
    }

    @Test
    fun push() {
        val d = PKeyDeque(2)
        d.push(1KeySuffix)
        d.push(2KeySuffix)
        assertEquals(listOf(2KeySuffix,1KeySuffix), d.toList())
        assertEquals(2KeySuffix, d.first())
    }

    @Test
    fun pop() {
        val d = PKeyDeque(3)
        d.addLast(1KeySuffix); d.addLast(2KeySuffix); d.addLast(3KeySuffix)
        assertEquals(1KeySuffix, d.pop())
        assertEquals(listOf(2KeySuffix,3KeySuffix), d.toList())
    }

    @Test
    fun enqueue() {
        val d = PKeyDeque(1)
        d.enqueue(1KeySuffix)
        d.enqueue(2KeySuffix)
        d.enqueue(3KeySuffix)
        assertEquals(listOf(1KeySuffix,2KeySuffix,3KeySuffix), d.toList())
        assertEquals(3KeySuffix, d.last())
    }

    @Test
    fun dequeue() {
        val d = PKeyDeque(2)
        d.addFirst(2KeySuffix)
        d.addFirst(1KeySuffix)
        assertEquals(1KeySuffix, d.dequeue())
        assertEquals(listOf(2KeySuffix), d.toList())
    }

    @Test
    fun asListReflectsChanges() {
        val d = PKeyDeque(2)
        d.addLast(1KeySuffix)
        d.addLast(2KeySuffix)
        val list = d.asList()
        assertEquals(listOf(1KeySuffix, 2KeySuffix), list)

        d.addFirst(0KeySuffix)
        assertEquals(listOf(0KeySuffix, 1KeySuffix, 2KeySuffix), list)

        d.removeLast()
        assertEquals(listOf(0KeySuffix, 1KeySuffix), list)
    }
